{
	"name": "birthdayy-discord-bot",
	"version": "0.2.3",
	"description": "Birthday Discord Bot built on Sapphire Framework",
	"author": "@chillihero",
	"main": "dist/index.js",
	"type": "module",
	"dependencies": {
		"@devtomio/plugin-botlist": "^1.3.0",
		"@kaname-png/plugin-subcommands-advanced": "^2.2.3",
		"@prisma/client": "^4.16.2",
		"@sapphire/cron": "^1.1.0",
		"@sapphire/decorators": "^6.0.1",
		"@sapphire/discord.js-utilities": "^7.0.0",
		"@sapphire/fetch": "^2.4.1",
		"@sapphire/framework": "^4.5.0",
		"@sapphire/plugin-api": "^5.1.0",
		"@sapphire/plugin-editable-commands": "^3.0.2",
		"@sapphire/plugin-hmr": "^2.0.1",
		"@sapphire/plugin-i18next": "^5.0.3",
		"@sapphire/plugin-logger": "^3.0.4",
		"@sapphire/plugin-scheduled-tasks": "^7.1.0",
		"@sapphire/plugin-subcommands": "^4.0.1",
		"@sapphire/plugin-utilities-store": "^1.0.1",
		"@sapphire/result": "^2.6.4",
		"@sapphire/stopwatch": "^1.5.0",
		"@sapphire/time-utilities": "^1.7.9",
		"@sapphire/type": "^2.4.0",
		"@sapphire/utilities": "^3.12.0",
		"@sentry/integrations": "^7.57.0",
		"@sentry/node": "^7.57.0",
		"@sentry/tracing": "^7.57.0",
		"@skyra/env-utilities": "^1.2.1",
		"bullmq": "^4.2.1",
		"colorette": "^2.0.20",
		"dayjs": "^1.11.9",
		"discord-api-types": "^0.37.48",
		"discord.js": "^14.11.0",
		"prisma": "^4.16.2",
		"reflect-metadata": "^0.1.13"
	},
	"devDependencies": {
		"@sapphire/cli": "^1.6.1",
		"@sapphire/eslint-config": "^4.4.3",
		"@sapphire/prettier-config": "^2.0.0",
		"@sapphire/ts-config": "^5.0.0",
		"@types/node": "^20.4.1",
		"@types/ws": "^8.5.5",
		"@typescript-eslint/eslint-plugin": "^5.62.0",
		"@typescript-eslint/parser": "^5.62.0",
		"eslint": "^8.44.0",
		"eslint-config-prettier": "^8.8.0",
		"eslint-plugin-prettier": "^5.0.0-alpha.2",
		"eslint-plugin-tsdoc": "^0.2.17",
		"husky": "^8.0.3",
		"lint-staged": "^13.2.3",
		"npm-run-all": "^4.1.5",
		"prettier": "^3.0.0",
		"tsc-watch": "^6.0.4",
		"typescript": "^5.1.6"
	},
	"scripts": {
		"build": "tsc -b src",
		"dev": "yarn build && yarn start",
		"watch": "tsc -b src -w",
		"watch:start": "tsc-watch -b src --onSuccess \"yarn start\"",
		"clean": "node scripts/clean.mjs",
		"start": "node --enable-source-maps dist/index.js",
		"doppler:start": "doppler run -- yarn start",
		"lint": "eslint --fix --ext ts src",
		"format": "prettier --write --log-level=warn \"{src,tests}/**/*.{js,ts,json}\"",
		"typeorm:schema:resync": "docker container rm -f postgres && docker volume rm postgres-data && docker volume create postgres-data && docker-compose -f ./.docker/docker-compose.yml up -d postgres && sleep 3 && yarn typeorm schema:sync",
		"update": "yarn upgrade-interactive"
	},
	"engines": {
		"node": "^20",
		"npm": "^10.0.0"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/BirthdayyBot/BirthdayyBotSapphire.git"
	},
	"commitlint": {
		"extends": [
			"@commitlint/config-conventional"
		]
	},
	"lint-staged": {
		"*": "prettier --ignore-unknown --write",
		"*.{mjs,js,ts}": "eslint --fix --ext mjs,js,ts"
	},
	"config": {
		"commitizen": {
			"path": "./node_modules/cz-conventional-changelog"
		}
	},
	"prettier": "@sapphire/prettier-config",
	"packageManager": "yarn@4.0.2",
	"volta": {
		"node": "20.10.0"
	},
	"maintainers": [
		{
			"name": "Swiizyy",
			"email": "williams@wbussat.fr",
			"url": "https://github.com/Swiizyy"
		}
	]
}
